@page
@model UcuzTeknoloji.Pages.Hesap.GirisYapModel
@{
    ViewData["Title"] = "Sisteme Giriş";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-light border-warning shadow-lg">
                <div class="card-body p-5">
                    <h2 class="text-center text-warning mb-4">Giriş Yap 🔐</h2>
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger fw-bold mb-3 bg-dark p-2 rounded" style="border-left: 4px solid red;"></div>
                        <div class="mb-3">
                            <label>Kullanıcı Adı</label>
                            <input type="text" asp-for="KullaniciAdi" class="form-control bg-secondary text-light border-0" required />
                        </div>
                        <div class="mb-4">
                            <label>Şifre</label>
                            <input type="password" asp-for="Sifre" class="form-control bg-secondary text-light border-0" required />
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold">Giriş Yap</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>