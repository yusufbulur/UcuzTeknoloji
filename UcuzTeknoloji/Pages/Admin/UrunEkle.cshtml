@page
@model UcuzTeknoloji.Pages.Admin.UrunEkleModel
@{
    ViewData["Title"] = "Gelişmiş Ürün Oluşturucu";
}

<style>
    .admin-panel-bg {
        background-color: #121212;
        min-height: 80vh;
        border-radius: 10px;
        padding: 30px;
        border: 1px solid #333;
    }

    .card-hover {
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }

        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(255, 102, 0, 0.2) !important;
            border-color: #ff6600 !important;
        }

    .form-control, .form-select {
        background-color: #1e1e1e;
        border: 1px solid #444;
        color: #fff;
        padding: 12px;
    }

        .form-control:focus, .form-select:focus {
            background-color: #252525;
            border-color: #ff6600;
            color: #fff;
            box-shadow: 0 0 8px rgba(255,102,0,0.5);
        }

    .section-title {
        color: #ff6600;
        font-weight: bold;
        border-bottom: 2px solid #333;
        padding-bottom: 10px;
        margin-bottom: 25px;
    }
</style>

<div class="container mt-4 mb-5">

    <div id="secimEkrani" class="admin-panel-bg shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-secondary pb-3">
            <h3 class="text-light m-0">🛠️ Ürün Yönetim Modülü</h3>
            <a href="/Admin/Index" class="btn btn-outline-secondary">🔙 Kontrol Merkezine Dön</a>
        </div>

        <div class="row justify-content-center gap-4">
            <div class="col-md-5">
                <div class="card bg-dark border-info text-center p-5 shadow card-hover h-100" onclick="EkraniAc('sablonEkrani')">
                    <h1 class="display-3 mb-3">📝</h1>
                    <h4 class="text-info fw-bold">1. Yeni Kategori / Şablon Yarat</h4>
                    <p class="text-muted small mt-2">Örn: "Monitör" adında bir şablon oluştur. Bu kategoriye özel "Ekran Boyutu", "Panel" gibi teknik detay başlıklarını belirle.</p>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card bg-dark border-warning text-center p-5 shadow card-hover h-100" onclick="EkraniAc('urunEklemeEkrani'); SablonlariYukle();">
                    <h1 class="display-3 mb-3">📦</h1>
                    <h4 class="text-warning fw-bold">2. Vitrine Yeni Ürün Ekle</h4>
                    <p class="text-muted small mt-2">Daha önce yarattığın bir şablonu seç, özelliklerin değerlerini doldur, resmini ve fiyatını ekleyip satışa sun.</p>
                </div>
            </div>
        </div>
    </div>

    <div id="sablonEkrani" class="admin-panel-bg shadow-lg d-none">
        <button class="btn btn-sm btn-secondary mb-4" onclick="EkraniAc('secimEkrani')">🔙 Geri Dön</button>

        <h4 class="section-title">Yeni Ürün Şablonu (Kategorisi) Tanımla</h4>

        <div class="row">
            <div class="col-md-6">
                <label class="text-light fw-bold mb-2">Şablon / Ürün Grubu Adı:</label>
                <input type="text" id="yeniSablonAdi" class="form-control mb-4" placeholder="Örn: Oyuncu Monitörü" />

                <div class="bg-dark p-3 rounded border border-secondary mb-3">
                    <p class="text-warning small m-0">⚠️ <b>Marka, Renk ve Fiyat</b> alanları her üründe sabit olarak sorulacaktır. Buraya sadece bu gruba ait ekstra özellikleri ekleyin.</p>
                </div>
            </div>

            <div class="col-md-6">
                <label class="text-light fw-bold mb-2">Ekstra Özellik Başlıkları:</label>
                <div id="ozellikBasliklariAlani">
                    <input type="text" class="form-control mb-2 sablon-input" placeholder="Örn: Ekran Boyutu" />
                </div>
                <button class="btn btn-outline-info w-100 mt-2 fw-bold" onclick="YeniBaslikEkle()">+ Yeni Özellik Başlığı Ekle</button>
            </div>
        </div>

        <button class="btn btn-info btn-lg fw-bold w-100 mt-5" onclick="SablonuKaydet()">💾 Şablonu Hafızaya Kaydet</button>
        <div class="mt-5 bg-dark p-4 border border-secondary rounded">
            <h5 class="text-warning border-bottom border-secondary pb-2">📋 Kayıtlı Şablonların</h5>
            <ul class="list-group list-group-flush bg-transparent mt-3" id="kayitliSablonlarListesi">
            </ul>
        </div>
    </div>

    <div id="urunEklemeEkrani" class="admin-panel-bg shadow-lg d-none">
        <button class="btn btn-sm btn-secondary mb-4" onclick="EkraniAc('secimEkrani')">🔙 Geri Dön</button>

        <h4 class="section-title">Oluşturulan Şablondan Ürün Ekle</h4>

        <label class="text-light fw-bold mb-2">Kullanılacak Şablonu Seçin:</label>
        <select id="sablonSecici" class="form-select mb-5 w-50" onchange="SablonunInputlariniGetir(this.value)">
            <option value="">-- Lütfen Bir Şablon Seçin --</option>
        </select>

        <form method="post" enctype="multipart/form-data" id="gercekFormAlani" class="d-none">
            <input type="hidden" name="SecilenSablonAdi" id="gizliSablonAdi" />

            <div class="row align-items-stretch">
                <div class="col-md-6 border-end border-secondary pe-md-4">
                    <h5 class="text-light mb-3">Temel Ürün Bilgileri</h5>
                    <input type="text" asp-for="YeniUrun.Name" class="form-control mb-3" placeholder="Ürün Adı (Örn: Asus 24 İnç 144Hz)" required />

                    <select asp-for="YeniUrun.CategoryId" class="form-select mb-3">
                        <option value="2">Bilgisayar Parçası / Çevre Birimi</option>
                        <option value="1">Hazır Sistem / Kasa</option>
                        <option value="3">Oyuncu Ekipmanı</option>
                    </select>

                    <div class="row mb-3">
                        <div class="col-6"><input type="number" asp-for="YeniUrun.Price" class="form-control" placeholder="Fiyat (₺)" required /></div>
                        <div class="col-6"><input type="number" asp-for="YeniUrun.Stock" class="form-control" placeholder="Stok Adedi" required /></div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-6"><input type="text" name="FixMarka" class="form-control" placeholder="Marka" required /></div>
                        <div class="col-6"><input type="text" name="FixRenk" class="form-control" placeholder="Renk" required /></div>
                    </div>

                    <label class="text-warning small fw-bold">Ürün Görseli (Zorunlu)</label>
                    <input type="file" name="UrunResmi" class="form-control border-warning bg-dark mb-3" required />
                </div>

                <div class="col-md-6 ps-md-4 mt-4 mt-md-0 d-flex flex-column">
                    <h5 class="text-warning mb-3">Teknik Detaylar (Şablona Özel)</h5>
                    <div class="bg-dark p-3 rounded border border-warning h-100" id="dinamikDegerlerAlani">
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-warning btn-lg fw-bold w-100 mt-4 text-dark shadow">🚀 Ürünü Kaydet ve Vitrine Gönder</button>
        </form>
    </div>
</div>

<script>
   
    function EkraniAc(ekranId) {
        document.getElementById('secimEkrani').classList.add('d-none');
        document.getElementById('sablonEkrani').classList.add('d-none');
        document.getElementById('urunEklemeEkrani').classList.add('d-none');

        document.getElementById(ekranId).classList.remove('d-none');

        
        if (ekranId === 'sablonEkrani') {
            SablonlariGuncelle();
        }
    }

    
    function SablonlariGuncelle() {
        let list = document.getElementById('kayitliSablonlarListesi');
        if (!list) return;

        list.innerHTML = "";
        let sablonlar = JSON.parse(localStorage.getItem("BenimSablonlarim")) || [];

        if (sablonlar.length === 0) {
            list.innerHTML = "<li class='list-group-item bg-transparent text-muted border-0 px-0'>Henüz hiç şablon eklemedin knk.</li>";
            return;
        }

        sablonlar.forEach((s, index) => {
            list.innerHTML += `
                    <li class="list-group-item bg-transparent text-light border-secondary d-flex justify-content-between align-items-center px-0">
                        <div>
                            <strong class="text-info">📌 ${s.isim}</strong>
                            <span class="text-muted small ms-2">(${s.ozellikler.length} Özellik)</span>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" onclick="SablonSil(${index})">🗑️ Sil</button>
                    </li>
                `;
        });
    }

    
    function SablonSil(index) {
        if (!confirm("Bu şablonu silmek istediğine emin misin?")) return;
        let sablonlar = JSON.parse(localStorage.getItem("BenimSablonlarim")) || [];
        sablonlar.splice(index, 1);
        localStorage.setItem("BenimSablonlarim", JSON.stringify(sablonlar)); 

        SablonlariGuncelle();
        SablonlariYukle(); 
    }

   
    function YeniBaslikEkle() {
        let alan = document.getElementById('ozellikBasliklariAlani');
       
        alan.insertAdjacentHTML('beforeend', `<input type="text" class="form-control mb-2 sablon-input border-info" placeholder="Yeni Özellik Adı" />`);
    }

    function SablonuKaydet() {
        let ad = document.getElementById('yeniSablonAdi').value;
        if (ad === "") { alert("Lütfen şablona bir isim verin!"); return; }

        let basliklar = [];
        document.querySelectorAll('.sablon-input').forEach(input => {
            if (input.value.trim() !== "") basliklar.push(input.value);
        });

        let sablonlar = JSON.parse(localStorage.getItem("BenimSablonlarim")) || [];
        sablonlar.push({ isim: ad, ozellikler: basliklar });
        localStorage.setItem("BenimSablonlarim", JSON.stringify(sablonlar));

        alert("✅ Şablon Başarıyla Kaydedildi! Şimdi 2. sekmeye geçip bu şablonla ürün ekleyebilirsiniz.");

       
        document.getElementById('yeniSablonAdi').value = "";
        EkraniAc('secimEkrani');
    }

    function SablonlariYukle() {
        let secici = document.getElementById('sablonSecici');
        secici.innerHTML = '<option value="">-- Lütfen Bir Şablon Seçin --</option>';
        let sablonlar = JSON.parse(localStorage.getItem("BenimSablonlarim")) || [];

        sablonlar.forEach((s, index) => {
            secici.innerHTML += `<option value="${index}">📌 ${s.isim}</option>`;
        });
    }

    function SablonunInputlariniGetir(index) {
        let formAlani = document.getElementById('gercekFormAlani');
        if (index === "") { formAlani.classList.add('d-none'); return; }
       
        
        let sablonlar = JSON.parse(localStorage.getItem("BenimSablonlarim")) || [];
        let secilenSablon = sablonlar[index];

        let alan = document.getElementById('dinamikDegerlerAlani');
        alan.innerHTML = ""; 

        if (secilenSablon.ozellikler.length === 0) {
            alan.innerHTML = "<p class='text-muted small m-0'>Bu şablona özel bir başlık eklenmemiş.</p>";
        } else {
            secilenSablon.ozellikler.forEach(ozellik => {
                alan.innerHTML += `
                        <div class="mb-3">
                            <label class="text-light small fw-bold mb-1">${ozellik}</label>
                            <input type="hidden" name="DynamicFeatureNames" value="${ozellik}" />
                            <input type="text" name="DynamicFeatureValues" class="form-control border-warning" placeholder="${ozellik} değerini girin..." required />
                        </div>
                    `;
            });
        }
        document.getElementById('gizliSablonAdi').value = secilenSablon.isim;
        formAlani.classList.remove('d-none');
    }
</script>